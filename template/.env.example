# ===========================================
# SEPIRING TEMPLATE - Environment Variables
# ===========================================
# Copy this file to .env and adjust values.
#   Dev: copy .env.dev .env
#   Prod: set as real OS environment variables
# ===========================================

# Application
APP_NAME=template
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ---- Primary Database (auto-configured) ----
DATABASE_URL=jdbc:h2:mem:template_db
DATABASE_USERNAME=sa
DATABASE_PASSWORD=
DATABASE_DRIVER=org.h2.Driver

# ---- Secondary Database (custom DataSource bean) ----
SECONDARY_DATABASE_URL=jdbc:h2:mem:secondary_db
SECONDARY_DATABASE_USERNAME=sa
SECONDARY_DATABASE_PASSWORD=
SECONDARY_DATABASE_DRIVER=org.h2.Driver

# ---- JPA / Hibernate ----
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_DIALECT=org.hibernate.dialect.H2Dialect

# ---- JWT ----
JWT_SECRET=change-me-to-base64-256-bit-secret
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ---- AES-CBC (cocok dengan NestJS sample.ts) ----
AES_KEY_B64=change-me-to-base64-256-bit-aes-key

# ---- Rate Limiting (Bucket4j) ----
RATE_LIMIT_PUBLIC_CAPACITY=100
RATE_LIMIT_PUBLIC_REFILL=100
RATE_LIMIT_AUTH_CAPACITY=60
RATE_LIMIT_AUTH_REFILL=60
RATE_LIMIT_RESET_SECONDS=60

# ---- File Storage (s3 | sftp | ftp) ----
FILE_STORAGE_TYPE=s3
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
SFTP_HOST=localhost
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
FTP_HOST=localhost
FTP_PORT=21
FTP_USERNAME=
FTP_PASSWORD=

# ---- Secondary Datasource JPA ----
SECONDARY_JPA_DDL_AUTO=update
SECONDARY_JPA_DIALECT=org.hibernate.dialect.H2Dialect

# ---- Flyway (set true in prod) ----
FLYWAY_ENABLED=false

# ---- Logging ----
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
